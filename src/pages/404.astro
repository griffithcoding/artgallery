---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Page not found — VERSO Gallery" robots="noindex, follow">
  <main class="wrap" style="min-height:60vh;display:flex;flex-direction:column;justify-content:center;align-items:center;text-align:center;padding-block:6rem;">
    <p class="eyebrow">404</p>
    <h1 class="display" style="font-size:clamp(2.5rem,8vw,5rem);margin:.5rem 0 1rem;">This wall is empty.</h1>
    <p class="lead muted" style="max-width:42ch;margin-bottom:2rem;">The page you’re looking for has moved or never existed. The collection, however, has plenty to look at.</p>
    <div class="flex gap-1" style="flex-wrap:wrap;justify-content:center;">
      <a class="btn btn--solid" href="/works">Browse the collection</a>
      <a class="btn" href="/">Back home</a>
    </div>
  </main>
</Layout>
