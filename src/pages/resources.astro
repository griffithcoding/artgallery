---
import Layout from '../layouts/Layout.astro';

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'CollectionPage',
    name: 'Resources — Mazlish + Wright Contemporary',
    url: 'https://www.versogallery.com/resources',
    isPartOf: { '@id': 'https://www.versogallery.com/#website' },
    about: { '@id': 'https://www.versogallery.com/#organization' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How do I start collecting art from Mazlish + Wright Contemporary?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Browse the available works online or visit the gallery, then use the Inquire button on any work. A gallery representative replies within one business day with availability, dimensions, framing, and shipping — with no pressure and no prices hidden behind a wall.',
        },
      },
      {
        '@type': 'Question',
        name: 'Does Mazlish + Wright Contemporary offer private art advisory?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. The gallery works with collectors at every level — from a first acquisition to building a considered collection — including private viewing rooms, studio introductions, and guidance on placement and care. Contact the gallery to arrange an advisory conversation.',
        },
      },
      {
        '@type': 'Question',
        name: 'Can I see works privately or request a viewing room?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. Viewing rooms edit the program down to a single idea, and the gallery can prepare a private selection on request. Email hello@versogallery.com or use any Inquire button.',
        },
      },
      {
        '@type': 'Question',
        name: 'How does shipping and care work?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Mazlish + Wright Contemporary arranges professional packing and shipping worldwide, with condition records for every work, and provides care and framing guidance for each acquisition.',
        },
      },
      {
        '@type': 'Question',
        name: 'Where can press find images and information?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Press can request high-resolution images, exhibition texts, and artist information from the gallery. See the Press page for recent coverage, or contact hello@versogallery.com for a press kit.',
        },
      },
    ],
  },
];
---
<Layout
  title="Resources — Collecting, Advisory & Press | Mazlish + Wright Contemporary, Brooklyn"
  description="Resources for collectors and press at Mazlish + Wright Contemporary: a plain-language guide to collecting, private art advisory, viewing rooms, shipping and care, and a downloadable press kit."
  keywords="art advisory Brooklyn, how to collect contemporary art, art collecting guide, gallery press kit, buy art NYC advisory"
  robots="index, follow, max-image-preview:large, max-snippet:-1"
  jsonLd={jsonLd}
>
  <main>
    <section class="wrap section--tight">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <span>Resources</span>
      </nav>
      <p class="eyebrow reveal">For collectors & press</p>
      <h1 class="display reveal" style="font-size:clamp(2.4rem,7vw,5rem);max-width:18ch;margin:.4rem 0 1.5rem;">Everything you need to look, learn, and acquire.</h1>
      <p class="lead reveal tldr-block" style="max-width:62ch;">Mazlish + Wright Contemporary is built to make collecting clear instead of intimidating. Whether this is your first acquisition or your fiftieth, these are the ways the gallery can help — and the answers to the questions we hear most.</p>
    </section>

    <section class="wrap section--tight">
      <div class="grid grid--3">
        <a class="resource-card reveal" href="#faq">
          <span class="resource-num">01</span>
          <h2 class="resource-title display">Collecting with Mazlish + Wright Contemporary</h2>
          <p class="muted">A plain-language guide to a first acquisition — how inquiries work, what to expect, and why every work shows a clear status.</p>
          <span class="link-underline">Read the guide →</span>
        </a>
        <a class="resource-card reveal" href="/contact">
          <span class="resource-num">02</span>
          <h2 class="resource-title display">Private Art Advisory</h2>
          <p class="muted">Build a considered collection with the gallery's directors — studio introductions, placement, and care, at every level.</p>
          <span class="link-underline">Arrange a conversation →</span>
        </a>
        <a class="resource-card reveal" href="/viewing-rooms">
          <span class="resource-num">03</span>
          <h2 class="resource-title display">Viewing Rooms</h2>
          <p class="muted">Curated selections that edit the program down to a single idea — and private rooms prepared on request.</p>
          <span class="link-underline">Enter the rooms →</span>
        </a>
        <a class="resource-card reveal" href="#faq">
          <span class="resource-num">04</span>
          <h2 class="resource-title display">Shipping & Care</h2>
          <p class="muted">Professional packing and worldwide shipping, condition records for every work, and framing and care guidance.</p>
          <span class="link-underline">How it works →</span>
        </a>
        <a class="resource-card reveal" href="/press">
          <span class="resource-num">05</span>
          <h2 class="resource-title display">Press Kit</h2>
          <p class="muted">High-resolution images, exhibition texts, and artist information for writers, editors, and institutions.</p>
          <span class="link-underline">Request the kit →</span>
        </a>
        <a class="resource-card reveal" href="/events">
          <span class="resource-num">06</span>
          <h2 class="resource-title display">Events & Programming</h2>
          <p class="muted">Openings, artist talks, and art-fair previews — the calendar, and how to RSVP before it's public.</p>
          <span class="link-underline">See what's on →</span>
        </a>
      </div>
    </section>

    <hr class="divider" />

    <section class="wrap section" id="faq">
      <div class="section-head"><h2 class="display reveal">Questions, answered</h2></div>
      <div class="faq-list">
        <details class="faq-item reveal" open>
          <summary>How do I start collecting art from Mazlish + Wright Contemporary?</summary>
          <p class="muted">Browse the available works online or visit the gallery, then use the <strong>Inquire</strong> button on any work. A representative replies within one business day with availability, dimensions, framing, and shipping — no pressure, and no prices hidden behind a wall.</p>
        </details>
        <details class="faq-item reveal">
          <summary>Does Mazlish + Wright Contemporary offer private art advisory?</summary>
          <p class="muted">Yes. The gallery works with collectors at every level — from a first acquisition to building a considered collection — including private viewing rooms, studio introductions, and guidance on placement and care. <a class="link-underline" href="/contact">Contact the gallery</a> to begin.</p>
        </details>
        <details class="faq-item reveal">
          <summary>Can I see works privately or request a viewing room?</summary>
          <p class="muted">Yes. Viewing rooms edit the program down to a single idea, and the gallery can prepare a private selection on request. Email <a class="link-underline" href="mailto:hello@versogallery.com">hello@versogallery.com</a> or use any Inquire button.</p>
        </details>
        <details class="faq-item reveal">
          <summary>How does shipping and care work?</summary>
          <p class="muted">Mazlish + Wright Contemporary arranges professional packing and shipping worldwide, keeps condition records for every work, and provides care and framing guidance for each acquisition.</p>
        </details>
        <details class="faq-item reveal">
          <summary>Where can press find images and information?</summary>
          <p class="muted">Press can request high-resolution images, exhibition texts, and artist information from the gallery. See the <a class="link-underline" href="/press">Press page</a> for recent coverage, or email the gallery for a press kit.</p>
        </details>
      </div>
    </section>

    <hr class="divider" />

    <section class="wrap section center">
      <h2 class="display reveal" style="max-width:22ch;margin:0 auto 1.4rem;">Talk to the gallery.</h2>
      <p class="muted reveal" style="margin-bottom:1.6rem;max-width:46ch;margin-inline:auto;">An advisory conversation starts with a simple message. We reply within one business day.</p>
      <div class="flex gap-1 reveal" style="justify-content:center;flex-wrap:wrap;">
        <a class="btn btn--solid" href="/contact">Contact &amp; advisory</a>
        <a class="btn" href="/works">Browse available works</a>
      </div>
    </section>
  </main>
</Layout>
