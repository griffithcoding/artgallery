---
import Layout from '../../layouts/Layout.astro';
import InquiryModal from '../../components/InquiryModal.astro';
import { getArtworks } from '../../lib/gallery';
import { BRAND } from '../../lib/site';

const artworks = await getArtworks();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Works — Mazlish + Wright Contemporary',
  description: 'A curated collection of contemporary artworks.',
  url: `${BRAND.domain}/works`,
  isPartOf: { '@id': `${BRAND.domain}/#website` },
  about: { '@type': 'Thing', name: 'Contemporary art in Brooklyn' },
};
---
<Layout
  title="Works — Browse Contemporary Artworks | Mazlish + Wright Contemporary Brooklyn"
  description="Browse Mazlish + Wright Contemporary’s curated collection of contemporary artworks. Filter by medium, category, artist, year, and availability. Painting, sculpture, photography, prints, and works on paper."
  keywords="contemporary artworks Brooklyn, browse art Brooklyn, contemporary paintings NYC, art for sale DUMBO, Mazlish + Wright Contemporary works"
  jsonLd={jsonLd}
>
  <main class="wrap section--tight">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <a href="/">Home</a> &nbsp;/&nbsp; <span>Works</span>
    </nav>
    <header style="margin-bottom:2rem;">
      <p class="eyebrow">The collection</p>
      <h1 class="display" style="font-size:clamp(2.2rem,5vw,3.5rem);margin:.4rem 0 .6rem;">Works</h1>
      <p class="lead tldr-block" style="max-width:60ch;">Browse the full collection and filter by medium, category, artist, year, and availability. Every work shows its current status.</p>
    </header>

    {artworks.length === 0 && (
      <p class="lead" style="max-width:60ch;">The collection is being prepared. Please check back soon, or <a class="link-underline" href="/contact">get in touch</a> to discuss available works.</p>
    )}

    {artworks.length > 0 && (
    <div class="collection-toolbar">
      <button class="btn filter-toggle-mobile" id="openFilters">Filters</button>
      <div class="search-box">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4.3-4.3"/></svg>
        <input type="search" id="search" placeholder="Search by artist, title, or medium…" aria-label="Search works" />
      </div>
      <select class="select" id="sort" aria-label="Sort works">
        <option value="featured">Sort: Featured</option>
        <option value="artist">Artist A–Z</option>
        <option value="year-desc">Year: Newest</option>
        <option value="year-asc">Year: Oldest</option>
      </select>
    </div>

    <div class="collection-layout">
      <aside class="filters" id="filters" aria-label="Filter works">
        <button class="filters-close" id="closeFilters" aria-label="Close filters">×</button>
        <div class="filter-group">
          <h4>Availability</h4>
          <div class="filter-list" id="filter-availability"></div>
        </div>
        <div class="filter-group">
          <h4>Category</h4>
          <div class="filter-list" id="filter-category"></div>
        </div>
        <div class="filter-group">
          <h4>Subject</h4>
          <div class="filter-list" id="filter-subject"></div>
        </div>
        <div class="filter-group">
          <h4>Artist</h4>
          <div class="filter-list" id="filter-artist"></div>
        </div>
        <div class="filter-group">
          <button class="link-underline" id="clearAll" style="background:none;border:none;">Clear all filters</button>
        </div>
      </aside>

      <div>
        <div class="active-filters" id="activeFilters"></div>
        <div class="result-count" id="resultCount" style="margin-bottom:1.2rem;"></div>
        <div class="grid grid--3" id="results"></div>
        <div id="empty" class="hidden center" style="padding:4rem 0;color:var(--ink-soft);">
          <p class="lead">No works match these filters.</p>
          <button class="btn mt-2" onclick="document.getElementById('clearAll').click()">Clear filters</button>
        </div>
        <div class="pagination" id="pagination"></div>
      </div>
    </div>
    )}
  </main>

  <script id="works-data" type="application/json" set:html={JSON.stringify(artworks).replace(/<\//g, '<\\/')}></script>
  <InquiryModal />
  <script>import '../../scripts/collection.ts';</script>
</Layout>
