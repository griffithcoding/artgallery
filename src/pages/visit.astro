---
import Layout from '../layouts/Layout.astro';
import { BRAND } from '../lib/site';

// Direct Google Maps embed endpoint (skips the ?output=embed 301 redirect, which
// carries X-Frame-Options: SAMEORIGIN and gets blocked inside an iframe).
const mapEmbed = 'https://www.google.com/maps/embed?origin=mfe&pb=!1m3!2m1!1s65B+Pearl+Street,+Brooklyn,+NY+11201!6i15';
const mapLink = 'https://www.google.com/maps/search/?api=1&query=65B+Pearl+Street+Brooklyn+NY+11201';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': ['ArtGallery', 'LocalBusiness'],
  '@id': `${BRAND.domain}/#organization`,
  name: 'Mazlish + Wright Contemporary',
  url: `${BRAND.domain}/`,
  image: `${BRAND.domain}/images/og-cover.svg`,
  telephone: '+1-718-555-0142',
  email: BRAND.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: '65B Pearl Street',
    addressLocality: 'Brooklyn',
    addressRegion: 'NY',
    postalCode: '11201',
    addressCountry: 'US',
  },
  geo: { '@type': 'GeoCoordinates', latitude: 40.7026, longitude: -73.9874 },
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
      opens: '13:00',
      closes: '18:00',
    },
  ],
  hasMap: mapLink,
};
---
<Layout
  title="Visit — Mazlish + Wright Contemporary, Brooklyn"
  description="Visit Mazlish + Wright Contemporary at 65B Pearl Street in DUMBO, Brooklyn. Open Tuesday–Saturday, 1–6pm. Free admission. Directions, hours, and contact details."
  jsonLd={jsonLd}
>
  <main class="wrap section--tight">
    <header style="margin-bottom:2.5rem;">
      <p class="eyebrow">DUMBO, Brooklyn</p>
      <h1 class="display" style="font-size:clamp(2.2rem,5vw,3.5rem);margin:.4rem 0 .6rem;">Visit</h1>
      <p class="lead tldr-block" style="max-width:58ch;">Mazlish + Wright Contemporary is located at 65B Pearl Street in DUMBO, Brooklyn. We’re open Tuesday through Saturday, 1–6pm, with Sunday and Monday by appointment.</p>
    </header>

    <div class="hero-grid" style="align-items:start;">
      <div>
        <h3 class="display" style="font-size:1.4rem;margin-bottom:.6rem;">Getting here</h3>
        <p class="prose">By subway: F to York Street, or A/C to High Street, both a short walk. The NYC Ferry stops at the DUMBO/Fulton Ferry landing nearby. Metered street parking is available on the surrounding streets.</p>
        <a class="btn mt-2" href={mapLink} target="_blank" rel="noopener">Open in Maps →</a>
      </div>
      <div class="visit-map">
        <iframe
          title="Map to Mazlish + Wright Contemporary — 65B Pearl Street, DUMBO, Brooklyn"
          src={mapEmbed}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          allowfullscreen></iframe>
      </div>
    </div>
  </main>
</Layout>

<style>
  .visit-map {
    width: 100%;
    aspect-ratio: 3 / 4;
    border: 1px solid var(--line);
    overflow: hidden;
    background: var(--line-soft, #f0f0f0);
  }
  .visit-map iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
    filter: grayscale(0.15);
  }
  @media (max-width: 900px) {
    .visit-map { aspect-ratio: 4 / 3; }
  }
</style>
