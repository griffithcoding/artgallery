---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createSupabaseAdmin } from '../../../lib/supabase/server';
import { artSVG, getArtistWorkCounts } from '../../../lib/gallery';
const { data: artists } = await createSupabaseAdmin()
  .from('artists')
  .select('id, name, discipline, portrait_image_url, featured, represented_since')
  .order('featured', { ascending: false })
  .order('name');
const counts = await getArtistWorkCounts();
const saved = Astro.url.searchParams.get('saved');
const list = (artists ?? []) as any[];
---
<AdminLayout title="Artists">
  <div class="admin-toolbar">
    <div>
      <h1 style="font-weight:500;">Artists</h1>
      <span class="admin-count">{list.length} {list.length === 1 ? 'artist' : 'artists'}</span>
    </div>
    <a class="admin-btn" href="/admin/artists/new">+ New artist</a>
  </div>
  {saved && <p class="admin-status" style="color:#5b7a4f;">Saved.</p>}
  {list.length === 0 && <p style="color:#6b6860;">No artists yet.</p>}
  <div class="admin-grid">
    {list.map((a) => (
      <div class="admin-tile">
        <a class="thumb portrait" href={`/admin/artists/${a.id}`}>
          <img src={a.portrait_image_url || artSVG(a.id, 'portrait')} alt={a.name} loading="lazy" />
        </a>
        <div class="tmeta">
          <a class="ttitle" href={`/admin/artists/${a.id}`}>{a.name}</a>
          <div class="tartist">
            {a.featured && <span style="color:var(--mw-accent);">★ </span>}
            {a.discipline}{a.discipline ? ' · ' : ''}{counts.get(a.id) ?? 0} works{a.represented_since ? ` · since ${a.represented_since}` : ''}
          </div>
          <div class="tactions">
            <a href={`/admin/artists/${a.id}`}>Edit</a>
            <form method="POST" action="/admin/artists/action" onsubmit="return confirm('Delete this artist?')">
              <input type="hidden" name="id" value={a.id} />
              <button class="tdel" type="submit">Delete</button>
            </form>
          </div>
        </div>
      </div>
    ))}
  </div>
</AdminLayout>
