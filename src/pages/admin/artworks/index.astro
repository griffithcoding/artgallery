---
export const prerender = false;
import AdminLayout from '../../../layouts/AdminLayout.astro';
import { createSupabaseAdmin } from '../../../lib/supabase/server';
import { artSVG } from '../../../lib/gallery';
const { data: works } = await createSupabaseAdmin()
  .from('artworks')
  .select('id, title, availability, image_url, ratio, artist:artists(name)')
  .order('created_at', { ascending: false });
const saved = Astro.url.searchParams.get('saved');
const list = (works ?? []) as any[];
---
<AdminLayout title="Artworks">
  <div class="admin-toolbar">
    <div>
      <h1 style="font-weight:500;">Artworks</h1>
      <span class="admin-count">{list.length} {list.length === 1 ? 'work' : 'works'}</span>
    </div>
    <a class="admin-btn" href="/admin/artworks/new">+ New artwork</a>
  </div>
  {saved && <p class="admin-status" style="color:#5b7a4f;">Saved.</p>}
  {list.length === 0 && (
    <p style="color:#6b6860;">No artworks yet. <a href="/admin/artworks/new" style="color:var(--mw-accent);">Add the first →</a></p>
  )}
  <div class="admin-grid">
    {list.map((w) => (
      <div class="admin-tile">
        <a class="thumb" href={`/admin/artworks/${w.id}`}>
          <span class={`badge ${String(w.availability).toLowerCase()}`}>{w.availability}</span>
          <img src={w.image_url || artSVG(w.id, w.ratio || 'square')} alt={w.title} loading="lazy" />
        </a>
        <div class="tmeta">
          <a class="ttitle" href={`/admin/artworks/${w.id}`}>{w.title}</a>
          <div class="tartist">{w.artist?.name ?? '—'}</div>
          <div class="tactions">
            <a href={`/admin/artworks/${w.id}`}>Edit</a>
            <form method="POST" action="/admin/artworks/action" onsubmit="return confirm('Delete this artwork?')">
              <input type="hidden" name="id" value={w.id} />
              <button class="tdel" type="submit">Delete</button>
            </form>
          </div>
        </div>
      </div>
    ))}
  </div>
</AdminLayout>
