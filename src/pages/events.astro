---
import Layout from '../layouts/Layout.astro';
import InquiryModal from '../components/InquiryModal.astro';

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Mazlish + Wright Contemporary — Upcoming Events',
  url: 'https://www.versogallery.com/events',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      item: {
        '@type': 'Event',
        name: 'Opening Reception — Summer Group Exhibition',
        startDate: '2026-06-26T18:00',
        endDate: '2026-06-26T20:00',
        eventStatus: 'https://schema.org/EventScheduled',
        eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
        isAccessibleForFree: true,
        location: {
          '@type': 'Place',
          name: 'Mazlish + Wright Contemporary',
          address: {
            '@type': 'PostalAddress',
            streetAddress: '312 Wythe Avenue',
            addressLocality: 'Brooklyn',
            addressRegion: 'NY',
            postalCode: '11249',
            addressCountry: 'US',
          },
        },
        organizer: { '@type': 'Organization', name: 'Mazlish + Wright Contemporary', url: 'https://www.versogallery.com/' },
        image: 'https://www.versogallery.com/images/og-cover.svg',
      },
    },
    {
      '@type': 'ListItem',
      position: 2,
      item: {
        '@type': 'Event',
        name: 'Artist Talk & Walkthrough',
        startDate: '2026-07-12T15:00',
        endDate: '2026-07-12T16:00',
        eventStatus: 'https://schema.org/EventScheduled',
        eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
        isAccessibleForFree: true,
        location: {
          '@type': 'Place',
          name: 'Mazlish + Wright Contemporary',
          address: {
            '@type': 'PostalAddress',
            streetAddress: '312 Wythe Avenue',
            addressLocality: 'Brooklyn',
            addressRegion: 'NY',
            postalCode: '11249',
            addressCountry: 'US',
          },
        },
        organizer: { '@type': 'Organization', name: 'Mazlish + Wright Contemporary', url: 'https://www.versogallery.com/' },
      },
    },
    {
      '@type': 'ListItem',
      position: 3,
      item: {
        '@type': 'Event',
        name: 'Mazlish + Wright Contemporary at NADA New York',
        startDate: '2026-09-10',
        endDate: '2026-09-13',
        eventStatus: 'https://schema.org/EventScheduled',
        eventAttendanceMode: 'https://schema.org/OfflineEventAttendanceMode',
        location: { '@type': 'Place', name: 'NADA New York' },
        organizer: { '@type': 'Organization', name: 'Mazlish + Wright Contemporary', url: 'https://www.versogallery.com/' },
      },
    },
  ],
};
---
<Layout
  title="Events — Openings, Talks & Art Fairs | Mazlish + Wright Contemporary, Brooklyn"
  description="Upcoming events at Mazlish + Wright Contemporary in Williamsburg, Brooklyn — exhibition openings, artist talks, curator walkthroughs, and art-fair appearances. Free and open to the public; RSVP encouraged."
  keywords="art events Brooklyn, gallery openings Williamsburg, artist talks NYC, art fair Brooklyn, contemporary art events"
  jsonLd={jsonLd}
>
  <main>
    <section class="wrap section--tight">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <span>Events</span>
      </nav>
      <p class="eyebrow reveal">Programming · Williamsburg, Brooklyn</p>
      <h1 class="display reveal" style="font-size:clamp(2.4rem,7vw,5rem);max-width:18ch;margin:.4rem 0 1.5rem;">Openings, talks, and fairs.</h1>
      <p class="lead reveal tldr-block" style="max-width:60ch;">Every Mazlish + Wright Contemporary exhibition opens with a public reception, and the program runs alongside artist talks, curator walkthroughs, and our appearances at art fairs. Events are free and open to the public — collectors, advisors, and first-time visitors all welcome. RSVP is encouraged so we can hold space for you.</p>
    </section>

    <section class="wrap section--tight">
      <ul class="event-list">
        <li class="event-item reveal">
          <div class="event-date"><span class="event-day">26</span><span class="event-mo">Jun</span></div>
          <div class="event-body">
            <p class="event-kind">Opening Reception</p>
            <h2 class="event-title display">Summer Group Exhibition</h2>
            <p class="muted">An evening with the artists. Thursday, June 26 · 6–8pm · 312 Wythe Avenue. Wine and conversation; the new installation on view for the first time.</p>
          </div>
          <div class="event-cta"><button class="link-underline" type="button" data-inquire="RSVP — Summer Group Opening, Jun 26">RSVP →</button></div>
        </li>
        <li class="event-item reveal">
          <div class="event-date"><span class="event-day">12</span><span class="event-mo">Jul</span></div>
          <div class="event-body">
            <p class="event-kind">Artist Talk & Walkthrough</p>
            <h2 class="event-title display">In the Studio, On the Wall</h2>
            <p class="muted">Saturday, July 12 · 3pm. An artist from the current show walks the gallery and talks process, with time for questions. Seating is limited.</p>
          </div>
          <div class="event-cta"><button class="link-underline" type="button" data-inquire="RSVP — Artist Talk, Jul 12">RSVP →</button></div>
        </li>
        <li class="event-item reveal">
          <div class="event-date"><span class="event-day">10</span><span class="event-mo">Sep</span></div>
          <div class="event-body">
            <p class="event-kind">Art Fair</p>
            <h2 class="event-title display">Mazlish + Wright Contemporary at NADA New York</h2>
            <p class="muted">September 10–13. Visit our booth for a focused presentation of new work. Request a preview and a complimentary pass from the gallery.</p>
          </div>
          <div class="event-cta"><button class="link-underline" type="button" data-inquire="NADA New York — preview & pass request">Request preview →</button></div>
        </li>
      </ul>
    </section>

    <hr class="divider" />

    <section class="wrap section center">
      <p class="eyebrow reveal">Never miss an opening</p>
      <h2 class="display reveal" style="max-width:20ch;margin:.6rem auto 1.4rem;">Get the invitation first.</h2>
      <p class="muted reveal" style="margin-bottom:1.6rem;max-width:48ch;margin-inline:auto;">Join the list for opening invitations, talk announcements, and fair previews — sent before they're public.</p>
      <form class="newsletter reveal" style="margin-inline:auto;border-color:var(--line);">
        <input type="email" required placeholder="Your email" aria-label="Email address" style="color:var(--ink);" />
        <button type="submit" style="color:var(--ink);">Join</button>
      </form>
    </section>
  </main>
  <InquiryModal />
</Layout>
<script>
  document.querySelectorAll('[data-inquire]').forEach((b) => {
    b.addEventListener('click', () => {
      (window as any).openInquiry(b.getAttribute('data-inquire'));
    });
  });
</script>
