---
import Layout from '../layouts/Layout.astro';
import ArtworkCard from '../components/ArtworkCard.astro';
import { getArtworks, getFeaturedArtworks, getExhibitions, getWorksByArtist, artSVG } from '../lib/gallery';
import { BRAND } from '../lib/site';

const allWorks = await getArtworks();
const works = await getFeaturedArtworks(8);
const exhibitions = await getExhibitions();
const current = exhibitions.find((e) => e.status === 'On View') ?? exhibitions[0];
const heroWork = (await getWorksByArtist(current.artistIds[0]))[0] ?? allWorks[0];

const mapsSearch = 'https://www.google.com/maps/search/?api=1&query=65-B+Pearl+Street+Brooklyn+NY+11201';
const mapsDir = 'https://www.google.com/maps/dir/?api=1&destination=65-B+Pearl+Street+Brooklyn+NY+11201';

// Visible FAQ — mirrored 1:1 into FAQPage schema below (local + answer-engine intent).
const faqs = [
  {
    q: 'Where is Mazlish + Wright Contemporary located?',
    a: 'Mazlish + Wright Contemporary is at 65-B Pearl Street in DUMBO, Brooklyn, NY 11201 — a short walk from the York Street (F) subway station and near the DUMBO/Fulton Ferry NYC Ferry landing.',
  },
  {
    q: 'What are Mazlish + Wright Contemporary’s opening hours?',
    a: 'The gallery is open Tuesday through Saturday, 1–6pm, with Sunday and Monday by appointment.',
  },
  {
    q: 'Is admission to Mazlish + Wright Contemporary free?',
    a: 'Yes. Mazlish + Wright Contemporary is free and open to the public — no ticket or appointment needed to walk in during opening hours.',
  },
  {
    q: 'What kind of art does Mazlish + Wright Contemporary show?',
    a: 'Mazlish + Wright Contemporary shows contemporary art by emerging and mid-career artists — painting, sculpture, photography, prints, and works on paper — with a new exhibition roughly every six weeks.',
  },
  {
    q: 'Can I buy art from Mazlish + Wright Contemporary?',
    a: 'Yes. Every available work has its own page with a clear status (Available, Inquire, or Sold) and an inquiry button. A gallery representative typically replies within one business day.',
  },
];

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': ['ArtGallery', 'LocalBusiness'],
      '@id': `${BRAND.domain}/#organization`,
      name: 'Mazlish + Wright Contemporary',
      alternateName: 'Mazlish + Wright Contemporary',
      url: `${BRAND.domain}/`,
      logo: `${BRAND.domain}/images/og-cover.svg`,
      image: `${BRAND.domain}/images/og-cover.svg`,
      description:
        'Contemporary art gallery in DUMBO, Brooklyn, showing original work by emerging and mid-career artists. Current exhibitions and works available to view and acquire.',
      slogan: 'Contemporary art in DUMBO, Brooklyn.',
      email: BRAND.email,
      telephone: '+1-718-555-0142',
      address: {
        '@type': 'PostalAddress',
        streetAddress: '65-B Pearl Street',
        addressLocality: 'Brooklyn',
        addressRegion: 'NY',
        postalCode: '11201',
        addressCountry: 'US',
      },
      geo: { '@type': 'GeoCoordinates', latitude: 40.7026, longitude: -73.9874 },
      hasMap: mapsSearch,
      areaServed: ['DUMBO', 'Brooklyn Heights', 'Downtown Brooklyn', 'Brooklyn', 'Manhattan', 'New York City'],
      openingHoursSpecification: [
        {
          '@type': 'OpeningHoursSpecification',
          dayOfWeek: ['Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'],
          opens: '13:00',
          closes: '18:00',
        },
      ],
      isAccessibleForFree: true,
      publicAccess: true,
      sameAs: ['https://www.instagram.com/', 'https://www.artsy.net/'],
    },
    {
      '@type': 'WebSite',
      '@id': `${BRAND.domain}/#website`,
      url: `${BRAND.domain}/`,
      name: 'Mazlish + Wright Contemporary',
      publisher: { '@id': `${BRAND.domain}/#organization` },
      inLanguage: 'en-US',
      potentialAction: {
        '@type': 'SearchAction',
        target: { '@type': 'EntryPoint', urlTemplate: `${BRAND.domain}/works?q={search_term_string}` },
        'query-input': 'required name=search_term_string',
      },
    },
    {
      '@type': 'FAQPage',
      '@id': `${BRAND.domain}/#faq`,
      mainEntity: faqs.map((f) => ({
        '@type': 'Question',
        name: f.q,
        acceptedAnswer: { '@type': 'Answer', text: f.a },
      })),
    },
  ],
};
---
<Layout
  title="Contemporary Art Gallery in DUMBO, Brooklyn | Mazlish + Wright Contemporary"
  description="Mazlish + Wright Contemporary is a free contemporary art gallery in DUMBO, Brooklyn — 65-B Pearl St, open Tue–Sat 1–6. See current exhibitions and original contemporary art by emerging and mid-career artists."
  keywords="contemporary art gallery Brooklyn, art gallery DUMBO, art galleries Brooklyn NYC, contemporary art Brooklyn, free art gallery Brooklyn, art exhibitions DUMBO, emerging artists Brooklyn, art gallery near me Brooklyn"
  jsonLd={jsonLd}
>
  <main>
    <!-- Hero — local, plain-language, answer-ready -->
    <section class="hero wrap">
      <div class="hero-grid">
        <div class="hero-copy">
          <p class="eyebrow reveal"><span class="dot" aria-hidden="true"></span>Now on view · DUMBO, Brooklyn</p>
          <h1 class="display reveal">A contemporary art gallery in DUMBO, Brooklyn.</h1>
          <p class="lead reveal tldr-block">Mazlish + Wright Contemporary is a free contemporary art gallery at 65-B Pearl Street in DUMBO, Brooklyn. Walk in Tuesday–Saturday to see new exhibitions and original work by emerging and mid-career artists, or browse the full collection online and inquire about any piece.</p>
          <dl class="hero-meta reveal">
            <div><dt>Now on view</dt><dd>{current.title}</dd></div>
            <div><dt>Hours</dt><dd>Tue–Sat, 1–6pm · Free</dd></div>
            <div><dt>Address</dt><dd>65-B Pearl St, Brooklyn</dd></div>
          </dl>
          <div class="flex gap-1 reveal" style="flex-wrap:wrap;">
            <a class="btn btn--solid" href="/visit">Plan your visit</a>
            <a class="btn" href="/works">Browse works</a>
          </div>
        </div>
        <div class="reveal">
          <a href={`/exhibitions/${current.slug}`} class="frame frame--hover" data-ratio="portrait" aria-label={`Current exhibition: ${current.title}`}>
            <img src={heroWork?.image ?? artSVG(current.slug, 'portrait')} alt={`Contemporary artwork from the exhibition ${current.title} at Mazlish + Wright Contemporary, DUMBO, Brooklyn`} width="600" height="800" />
          </a>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- Selected works -->
    <section class="section wrap">
      <div class="section-head">
        <h2 class="display reveal">Contemporary art, available now</h2>
        <a class="link-underline reveal" href="/works">View all works →</a>
      </div>
      <div class="grid grid--4">
        {works.map((w) => <ArtworkCard work={w} />)}
      </div>
    </section>

    <hr class="divider" />

    <!-- Visit / local NAP block -->
    <section class="section wrap">
      <div class="hero-grid">
        <div class="reveal">
          <p class="eyebrow">Visit the gallery</p>
          <h2 class="display" style="margin:.5rem 0 1.2rem;">See it in person on Pearl Street.</h2>
          <p class="prose">Mazlish + Wright Contemporary is in DUMBO, a few minutes from the Brooklyn waterfront and the Manhattan and Brooklyn bridges. Admission is free, and no appointment is needed during opening hours.</p>
          <address class="visit-nap">
            <strong>Mazlish + Wright Contemporary</strong><br />
            65-B Pearl Street, Brooklyn, NY 11201<br />
            Tuesday–Saturday, 1–6pm · Free admission<br />
            <a href="tel:+17185550142">+1 (718) 555-0142</a> · <a href={`mailto:${BRAND.email}`}>{BRAND.email}</a>
          </address>
          <p class="muted" style="font-size:.9rem;margin-top:1rem;">Getting here: a short walk from the York Street (F) station; near the DUMBO NYC Ferry landing; metered street parking nearby.</p>
          <div class="flex gap-1 mt-2" style="flex-wrap:wrap;">
            <a class="btn btn--solid" href={mapsDir} rel="noopener" target="_blank">Get directions</a>
            <a class="btn" href="/visit">More visit info</a>
          </div>
        </div>
        <div class="reveal">
          <a href="/exhibitions" class="frame frame--hover" data-ratio="landscape" aria-label="Exhibitions at Mazlish + Wright Contemporary">
            <img src={allWorks[12]?.image ?? artSVG('verso-visit', 'landscape')} alt="Inside Mazlish + Wright Contemporary, a contemporary art gallery in DUMBO, Brooklyn" />
          </a>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <!-- FAQ — local + answer-engine intent (mirrors FAQPage schema) -->
    <section class="section wrap">
      <div class="section-head"><h2 class="display reveal">Visiting Mazlish + Wright Contemporary — quick answers</h2></div>
      <div class="faq-list">
        {faqs.map((f, i) => (
          <details class="faq-item reveal" open={i === 0}>
            <summary>{f.q}</summary>
            <p class="muted">{f.a}</p>
          </details>
        ))}
      </div>
    </section>

    <hr class="divider" />

    <!-- Newsletter -->
    <section class="section--tight wrap center">
      <p class="eyebrow reveal">Mailing list</p>
      <h2 class="display reveal" style="max-width:20ch;margin:.6rem auto 1.4rem;">New exhibitions and openings, first.</h2>
      <form class="newsletter reveal" style="margin-inline:auto;border-color:var(--line);">
        <input type="email" required placeholder="Your email" aria-label="Email address" style="color:var(--ink);" />
        <button type="submit" style="color:var(--ink);">Join</button>
      </form>
    </section>
  </main>
</Layout>

<style>
  .visit-nap { font-style: normal; line-height: 1.85; font-size: 0.95rem; margin: 1.2rem 0; color: var(--ink); }
  .visit-nap a { border-bottom: 1px solid var(--line); }
  .visit-nap a:hover { border-color: var(--ink); }
</style>
