---
import Layout from '../../layouts/Layout.astro';
import ArtistCard from '../../components/ArtistCard.astro';
import { getArtists, getWorksByArtist, artSVG } from '../../lib/gallery';
import { BRAND } from '../../lib/site';

const allArtists = await getArtists();
const cards = await Promise.all(
  allArtists.map(async (a) => {
    const works = await getWorksByArtist(a.id);
    const image = works[0]?.image ?? artSVG(a.id, 'portrait');
    const letter = a.name.split(' ').pop()![0].toUpperCase();
    return { artist: a, image, letter };
  })
);
const letters = [...new Set(cards.map((c) => c.letter))].sort();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${BRAND.domain}/` },
    { '@type': 'ListItem', position: 2, name: 'Artists', item: `${BRAND.domain}/artists` },
  ],
};
---
<Layout
  title="Artists — VERSO Gallery Brooklyn"
  description="The artists represented by VERSO Gallery in Brooklyn — emerging and mid-career painters, sculptors, photographers, and printmakers. Browse biographies and available works."
  jsonLd={jsonLd}
>
  <main class="wrap section--tight">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <a href="/">Home</a> &nbsp;/&nbsp; <span>Artists</span>
    </nav>
    <header style="margin-bottom:2rem;">
      <p class="eyebrow">Represented</p>
      <h1 class="display" style="font-size:clamp(2.2rem,5vw,3.5rem);margin:.4rem 0 .6rem;">Artists</h1>
      <p class="lead" style="max-width:60ch;">VERSO works with emerging and mid-career artists across painting, sculpture, photography, and works on paper. Each artist’s page links to their full set of available works.</p>
    </header>

    {allArtists.length === 0 ? (
      <p class="lead" style="max-width:60ch;">Artist profiles are coming soon.</p>
    ) : (
      <>
        <div class="artist-letter-nav" id="letterNav">
          <button data-l="all">All</button>
          {letters.map((l) => <button data-l={l}>{l}</button>)}
        </div>
        <div class="grid grid--4" id="artistGrid">
          {cards.map((c) => (
            <div data-letter={c.letter}>
              <ArtistCard artist={c.artist} image={c.image} />
            </div>
          ))}
        </div>
      </>
    )}
  </main>
  <script>
    const nav = document.getElementById('letterNav');
    const grid = document.getElementById('artistGrid');
    nav?.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.tagName !== 'BUTTON') return;
      const l = target.dataset.l;
      grid?.querySelectorAll<HTMLElement>('[data-letter]').forEach((c) => {
        c.style.display = l === 'all' || c.dataset.letter === l ? '' : 'none';
      });
    });
  </script>
</Layout>
