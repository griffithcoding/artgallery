---
import Layout from '../../layouts/Layout.astro';
import { getArtists, getWorksByArtist, artSVG } from '../../lib/gallery';
import { BRAND } from '../../lib/site';

const allArtists = await getArtists();
const cards = await Promise.all(
  allArtists.map(async (a) => {
    const works = await getWorksByArtist(a.id);
    const image = works[0]?.image ?? artSVG(a.id, 'portrait');
    return { artist: a, image };
  })
);

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${BRAND.domain}/` },
    { '@type': 'ListItem', position: 2, name: 'Artists', item: `${BRAND.domain}/artists` },
  ],
};
---
<Layout
  title="Artists — Mazlish + Wright Contemporary Brooklyn"
  description="The artists represented by Mazlish + Wright Contemporary in Brooklyn — emerging and mid-career painters, sculptors, photographers, and printmakers. Browse biographies and available works."
  jsonLd={jsonLd}
>
  <main class="wrap section--tight">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <a href="/">Home</a> &nbsp;/&nbsp; <span>Artists</span>
    </nav>
    <header style="margin-bottom:2.5rem;">
      <p class="eyebrow">Represented</p>
      <h1 class="display" style="font-size:clamp(2.2rem,5vw,3.5rem);margin:.4rem 0 .6rem;">Artists</h1>
    </header>

    {allArtists.length === 0 ? (
      <p class="lead" style="max-width:60ch;">Artist profiles are coming soon.</p>
    ) : (
      <ul class="artist-index">
        {cards.map((c) => (
          <li>
            <a class="aii" href={`/artists/${c.artist.slug}`}>
              <span class="aii-img"><img src={c.image} alt={`Work by ${c.artist.name}`} loading="lazy" />{c.artist.featured && <span class="aii-badge">Featured</span>}</span>
              <span class="aii-name">{c.artist.name}</span>
              <span class="aii-disc">{c.artist.discipline}</span>
            </a>
          </li>
        ))}
      </ul>
    )}
  </main>
</Layout>

<style>
  .artist-index {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.8rem, 3.2vw, 3.4rem) clamp(1.2rem, 2.5vw, 2.4rem);
  }
  .aii { display: block; text-decoration: none; color: inherit; }
  .aii-img {
    display: block;
    position: relative;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: var(--line-soft, #f0f0f0);
  }
  .aii-badge {
    position: absolute; top: 0.7rem; left: 0.7rem;
    font-size: 0.6rem; letter-spacing: 0.14em; text-transform: uppercase;
    padding: 0.3rem 0.6rem; background: var(--paper); color: var(--accent-2);
    border: 1px solid var(--line);
  }
  .aii-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.7s var(--ease);
  }
  .aii:hover .aii-img img { transform: scale(1.045); }
  .aii-name {
    display: block;
    margin-top: 1rem;
    font-size: 1.05rem;
    letter-spacing: 0.005em;
    color: var(--ink);
    text-align: center;
  }
  .aii-disc {
    display: block;
    margin-top: 0.2rem;
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-soft);
    text-align: center;
  }
  @media (max-width: 900px) { .artist-index { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .artist-index { grid-template-columns: 1fr; gap: 2.2rem; } }
</style>
