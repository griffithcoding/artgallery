---
import Layout from '../layouts/Layout.astro';
import { getPress } from '../lib/gallery';
import { BRAND } from '../lib/site';

const press = await getPress();

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${BRAND.domain}/` },
    { '@type': 'ListItem', position: 2, name: 'Press', item: `${BRAND.domain}/press` },
  ],
};
---
<Layout
  title="Press — Mazlish + Wright Contemporary, Brooklyn"
  description="Press and media coverage of Mazlish + Wright Contemporary, Brooklyn — features, reviews, and listings in Artforum, The New York Times, Hyperallergic, ARTnews, and more."
  jsonLd={jsonLd}
>
  <main class="wrap section--tight">
    <nav aria-label="Breadcrumb" class="breadcrumb">
      <a href="/">Home</a> &nbsp;/&nbsp; <span>Press</span>
    </nav>
    <header style="margin-bottom:2.5rem;">
      <p class="eyebrow">In the press</p>
      <h1 class="display" style="font-size:clamp(2.2rem,5vw,3.5rem);margin:.4rem 0 .6rem;">Press</h1>
      <p class="lead" style="max-width:58ch;">Selected coverage of the gallery, its artists, and its curated collection. For images, interviews, or press releases, contact <a class="link-underline" href="mailto:press@versogallery.com">press@versogallery.com</a>.</p>
    </header>
    <div id="pressList">
      {press.map((p) => (
        <div class="press-item">
          <div><span class="outlet">{p.outlet}</span><div class="date">{p.kind}</div></div>
          <div>{p.headline}</div>
          <div class="date">{p.date}</div>
        </div>
      ))}
    </div>
  </main>
</Layout>
