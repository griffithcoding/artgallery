---
import Layout from '../layouts/Layout.astro';
import { getArtworks, getArtists } from '../lib/gallery';
import { BRAND } from '../lib/site';

const artistCount = (await getArtists()).length;
const heroImage = (await getArtworks())[7].image;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: 'About VERSO Gallery',
    url: `${BRAND.domain}/about`,
    isPartOf: { '@id': `${BRAND.domain}/#website` },
    about: { '@id': `${BRAND.domain}/#organization` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Where is VERSO Gallery located?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'VERSO is at 312 Wythe Avenue in Williamsburg, Brooklyn, NY 11249. The gallery is open Tuesday through Saturday, 11am to 6pm.',
        },
      },
      {
        '@type': 'Question',
        name: 'Does VERSO show availability?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. VERSO publishes a clear status (Available, Inquire, or Sold) on every work in its online collection.',
        },
      },
      {
        '@type': 'Question',
        name: 'Can I buy art from VERSO online?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. Every available work has its own page and an inquiry button. A gallery representative confirms availability, shipping, and payment, typically within one business day.',
        },
      },
      {
        '@type': 'Question',
        name: 'What kind of art does VERSO sell?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'VERSO represents emerging and mid-career contemporary artists working in painting, sculpture, photography, prints, and works on paper.',
        },
      },
    ],
  },
];
---
<Layout
  title="About — VERSO Gallery, Brooklyn"
  description="VERSO is an independent contemporary art gallery in Williamsburg, Brooklyn, founded in 2015. We show our full program in the open — every available work browsable, with a clear status."
  jsonLd={jsonLd}
>
  <main>
    <section class="wrap section--tight">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <span>About</span>
      </nav>
      <p class="eyebrow reveal">Since 2015 · Williamsburg, Brooklyn</p>
      <h1 class="display reveal" style="font-size:clamp(2.4rem,7vw,5rem);max-width:16ch;margin:.4rem 0 1.5rem;">A gallery that keeps its archive open.</h1>
      <p class="lead reveal tldr-block" style="max-width:60ch;">VERSO is an independent contemporary art gallery in Brooklyn. We represent emerging and mid-career artists, mount a new exhibition roughly every six weeks, and — unusually — put our full program online, every available work on its own page, browsable in full.</p>
    </section>

    <div class="frame reveal" data-ratio="landscape" id="aboutHero">
      <img src={heroImage} alt="Inside VERSO Gallery, Brooklyn" />
    </div>

    <section class="wrap section">
      <div class="hero-grid">
        <div class="reveal">
          <p class="eyebrow">What we believe</p>
          <h2 class="display" style="margin:.5rem 0 1.2rem;">Access is the program.</h2>
        </div>
        <div class="prose reveal">
          <p>For most of the art world’s history, the whole program has lived in the back room — visible only to a few. We think that’s backwards. So we show the whole program in the open, every available work on its own page with clear status, for anyone who wants to look.</p>
          <p>That openness shapes everything: a website that shows the program in the open, viewing rooms that edit it down to a single idea, and a front desk that answers questions in plain language. The art is ambitious. The buying shouldn’t be intimidating.</p>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <section class="wrap section--tight">
      <div class="stat-band">
        <div class="reveal"><div class="num">2015</div><div class="label">Founded in Brooklyn</div></div>
        <div class="reveal"><div class="num" id="aArtists">{artistCount}</div><div class="label">Artists</div></div>
        <div class="reveal"><div class="num">60+</div><div class="label">Exhibitions to date</div></div>
        <div class="reveal"><div class="num">4</div><div class="label">Art fairs / year</div></div>
      </div>
    </section>

    <hr class="divider" />

    <section class="wrap section">
      <div class="section-head"><h2 class="display reveal">The team</h2></div>
      <div class="grid grid--3">
        <div class="reveal">
          <h3 class="display" style="font-size:1.4rem;">Founder & Director</h3>
          <p class="muted">Leads the program, artist relationships, and acquisitions. Previously a curator and art advisor with fifteen years across New York galleries.</p>
        </div>
        <div class="reveal">
          <h3 class="display" style="font-size:1.4rem;">Senior Director, Sales</h3>
          <p class="muted">Works with collectors at every level — from first purchases to building considered collections — and runs the gallery’s viewing-room program.</p>
        </div>
        <div class="reveal">
          <h3 class="display" style="font-size:1.4rem;">Registrar & Archive</h3>
          <p class="muted">Maintains the catalogue, condition records, and the logistics of shipping art anywhere in the world.</p>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <section class="wrap section center">
      <h2 class="display reveal" style="max-width:20ch;margin:0 auto 1.4rem;">Come see it in person.</h2>
      <p class="muted reveal" style="margin-bottom:1.6rem;">312 Wythe Avenue, Brooklyn · Tue–Sat, 11–6</p>
      <div class="flex gap-1 reveal" style="justify-content:center;flex-wrap:wrap;">
        <a class="btn btn--solid" href="/visit">Plan your visit</a>
        <a class="btn" href="/works">Browse the archive</a>
      </div>
    </section>
  </main>
</Layout>
