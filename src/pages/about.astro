---
import Layout from '../layouts/Layout.astro';
import { getArtworks, getArtists } from '../lib/gallery';
import { BRAND } from '../lib/site';

const artistCount = (await getArtists()).length;
const heroImage = (await getArtworks())[7].image;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'AboutPage',
    name: 'About Mazlish + Wright Contemporary',
    url: `${BRAND.domain}/about`,
    isPartOf: { '@id': `${BRAND.domain}/#website` },
    about: { '@id': `${BRAND.domain}/#organization` },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'Where is Mazlish + Wright Contemporary located?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Mazlish + Wright Contemporary is at 65B Pearl Street in DUMBO, Brooklyn, NY 11201. The gallery is open Tuesday through Saturday, 1–6pm, with Sunday and Monday by appointment.',
        },
      },
      {
        '@type': 'Question',
        name: 'Does Mazlish + Wright Contemporary show availability?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. Mazlish + Wright Contemporary publishes a clear status (Available, Inquire, or Sold) on every work in its online collection.',
        },
      },
      {
        '@type': 'Question',
        name: 'Can I buy art from Mazlish + Wright Contemporary online?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. Every available work has its own page and an inquiry button. A gallery representative confirms availability, shipping, and payment, typically within one business day.',
        },
      },
      {
        '@type': 'Question',
        name: 'What kind of art does Mazlish + Wright Contemporary sell?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Mazlish + Wright Contemporary represents emerging and mid-career contemporary artists working in painting, sculpture, photography, prints, and works on paper.',
        },
      },
    ],
  },
];
---
<Layout
  title="About — Mazlish + Wright Contemporary, Brooklyn"
  description="Mazlish + Wright Contemporary is an independent contemporary art gallery in DUMBO, Brooklyn, founded in 2015, representing emerging and mid-career artists. Every available work is online with its current status."
  jsonLd={jsonLd}
>
  <main>
    <section class="wrap section--tight">
      <nav aria-label="Breadcrumb" class="breadcrumb">
        <a href="/">Home</a> &nbsp;/&nbsp; <span>About</span>
      </nav>
      <p class="eyebrow reveal">Since 2015 · DUMBO, Brooklyn</p>
      <h1 class="display reveal" style="font-size:clamp(2.4rem,7vw,5rem);max-width:16ch;margin:.4rem 0 1.5rem;">A gallery that keeps its archive open.</h1>
      <p class="lead reveal tldr-block" style="max-width:60ch;">Mazlish + Wright Contemporary is an independent contemporary art gallery in Brooklyn. We represent emerging and mid-career artists and mount a new exhibition roughly every six weeks. The full program is online — every available work on its own page, with its current status shown.</p>
    </section>

    <div class="frame reveal" data-ratio="landscape" id="aboutHero">
      <img src={heroImage} alt="Inside Mazlish + Wright Contemporary, Brooklyn" />
    </div>

    <section class="wrap section">
      <div class="hero-grid">
        <div class="reveal">
          <p class="eyebrow">What we believe</p>
          <h2 class="display" style="margin:.5rem 0 1.2rem;">Nothing kept in the back room.</h2>
        </div>
        <div class="prose reveal">
          <p>Most galleries keep the bulk of their program in a back room, shown only on request. We do the opposite: the whole program is online, every available work on its own page with its current status, open to anyone who wants to look.</p>
          <p>The same approach runs through the gallery — a website you can browse in full, viewing rooms built around a single idea, and staff on hand to answer questions and arrange viewings.</p>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <section class="wrap section--tight">
      <div class="stat-band">
        <div class="reveal"><div class="num">2015</div><div class="label">Founded in Brooklyn</div></div>
        <div class="reveal"><div class="num" id="aArtists">{artistCount}</div><div class="label">Artists</div></div>
        <div class="reveal"><div class="num">60+</div><div class="label">Exhibitions to date</div></div>
        <div class="reveal"><div class="num">4</div><div class="label">Art fairs / year</div></div>
      </div>
    </section>

    <hr class="divider" />

    <section class="wrap section">
      <div class="section-head"><h2 class="display reveal">The team</h2></div>
      <div class="grid grid--3">
        <div class="reveal">
          <h3 class="display" style="font-size:1.4rem;">Founder & Director</h3>
          <p class="muted">Leads the program, artist relationships, and acquisitions. Previously a curator and art advisor with fifteen years across New York galleries.</p>
        </div>
        <div class="reveal">
          <h3 class="display" style="font-size:1.4rem;">Senior Director, Sales</h3>
          <p class="muted">Works with collectors at every level — from first purchases to building considered collections — and runs the gallery’s viewing-room program.</p>
        </div>
        <div class="reveal">
          <h3 class="display" style="font-size:1.4rem;">Registrar & Archive</h3>
          <p class="muted">Maintains the catalogue, condition records, and the logistics of shipping art anywhere in the world.</p>
        </div>
      </div>
    </section>

    <hr class="divider" />

    <section class="wrap section center">
      <h2 class="display reveal" style="max-width:20ch;margin:0 auto 1.4rem;">Come see it in person.</h2>
      <p class="muted reveal" style="margin-bottom:1.6rem;">65B Pearl Street, Brooklyn · Tue–Sat, 1–6</p>
      <div class="flex gap-1 reveal" style="justify-content:center;flex-wrap:wrap;">
        <a class="btn btn--solid" href="/visit">Plan your visit</a>
        <a class="btn" href="/works">Browse the archive</a>
      </div>
    </section>
  </main>
</Layout>
